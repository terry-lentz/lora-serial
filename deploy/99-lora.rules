# 99-lora.rules — stable device name for the LoRa modem board + keep ModemManager
# off it. Without this, the kernel name (ttyACM0/ttyACM1) can swap on replug/reboot,
# and on some distros ModemManager grabs /dev/ttyACM* and breaks the getty/terminal.
#
# Install:
#   sudo cp deploy/99-lora.rules /etc/udev/rules.d/
#   sudo udevadm control --reload && sudo udevadm trigger
#   ls -l /dev/lora            # -> symlink to the board's ttyACMx
#
# Then point the console at the stable name:
#   sudo systemctl enable --now lora-getty@lora
#
# IMPORTANT: verify your board's USB IDs first (XIAO ESP32S3 native USB is usually
# Espressif 303a, but confirm), then edit idVendor/idProduct below if needed:
#   udevadm info -a -n /dev/ttyACM0 | grep -m2 -E 'idVendor|idProduct'
#
# If you run TWO boards on one host, match a unique attribute instead (serial number
# or USB path) so each gets its own name, e.g. ATTRS{serial}=="...", SYMLINK+="loraA".

# Espressif-native USB (303a) and Seeed XIAO boards (2886, e.g. the newer
# XIAO-S3 / HaLow variants) both appear here. Match either vendor.
SUBSYSTEM=="tty", SUBSYSTEMS=="usb", ATTRS{idVendor}=="303a", \
    SYMLINK+="lora", ENV{ID_MM_DEVICE_IGNORE}="1", MODE="0660", GROUP="dialout"
SUBSYSTEM=="tty", SUBSYSTEMS=="usb", ATTRS{idVendor}=="2886", \
    SYMLINK+="lora", ENV{ID_MM_DEVICE_IGNORE}="1", MODE="0660", GROUP="dialout"
